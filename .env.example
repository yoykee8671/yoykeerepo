NODE_ENV=production
HOST=0.0.0.0
PORT=4173

# Supabase Postgres or any Postgres URL
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Initial admin bootstrap on first empty database only
BOOTSTRAP_ADMIN_NAME=Owner
BOOTSTRAP_ADMIN_EMAIL=owner@wooofpay.local
# Required in production. In development, leave blank to auto-generate a temporary password printed to the server console once.
BOOTSTRAP_ADMIN_PASSWORD=

# Optional Google Sheets archive sync
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=
